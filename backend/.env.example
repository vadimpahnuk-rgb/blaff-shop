# Database (Supabase pooler connection string in production)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Telegram Bot Token (from BotFather)
BOT_TOKEN=your_bot_token_here

# NowPayments
NOWPAYMENTS_API_KEY=your_nowpayments_api_key_here
NOWPAYMENTS_IPN_SECRET=your_ipn_secret_here
# Crypto the buyer pays in (default: USDT on TRON)
NOWPAYMENTS_PAY_CURRENCY=usdttrc20

# Server
PORT=3001
NODE_ENV=development

# Public URLs
# Frontend Mini App URL (used by the bot's WebApp button) — must be https in prod
APP_URL=https://your-frontend-domain.vercel.app
# This backend's own public URL (used to build the NowPayments IPN callback)
PUBLIC_URL=https://your-backend-domain.vercel.app
# Allowed CORS origin (the frontend)
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Support contact shown by the bot /support command
SUPPORT_HANDLE=@blaff_support
